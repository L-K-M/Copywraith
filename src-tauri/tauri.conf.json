{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Copywraith",
	"version": "0.1.0",
	"identifier": "ch.lkmc.copywraith",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"label": "popup",
				"title": "Copywraith",
				"width": 560,
				"height": 480,
				"minWidth": 400,
				"minHeight": 300,
			"decorations": false,
			"visible": false,
			"skipTaskbar": true,
				"resizable": true,
				"transparent": false
			}
		],
		"security": {}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"android": {
			"minSdkVersion": 24
		}
	}
}
